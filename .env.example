# Supabase Configuration
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Gemini API Key (handled by platform, but can be set for local dev)
GEMINI_API_KEY=

# Custom Templates (JSON array string)
# Example: VITE_CUSTOM_TEMPLATES='[{"title": "Custom", "iconName": "Zap", "description": "Desc", "prompt": "Prompt"}]'
VITE_CUSTOM_TEMPLATES=
